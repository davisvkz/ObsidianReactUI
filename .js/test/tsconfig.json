{
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "bundler",
		"target": "ES2022",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"types": [
			"node",
			"@wdio/globals/types",
			"@wdio/mocha-framework",
			"wdio-obsidian-service"
		]
	},
	"include": ["specs/**/*.ts", "../wdio.conf.mts"]
}
